0\u5de7 \u524d\u5f80 \u2192 \u6742\u4e8b\u7eb7\u7ead \u505a\u7684\u5176\u4ed6\u7684\u4e0d\u52a1\u6b63\u4e1a\u7684\u4e8b\u60c5 \u524d\u5f80 \u2192 \u9e1f \u89c2\u9e1f\u8bb0\u5f55 \ud83d\udc26 \u524d\u5f80 \u2192 \u788e\u788e\u5ff5 \u65e5\u5e38\u77ed\u7bc7\u3001\u751f\u6d3b\u7410\u4e8b\u3001\u968f\u60f3 \u524d\u5f80 \u2192"},{"location":"#_7","title":"\ud83d\udea7 \u6b63\u5728\u52aa\u529b\u66f4\u65b0","text":"<p>\u8ba1\u5212</p> <ul> <li>\u5b8c\u5584\u8bfe\u7a0b\u7b14\u8bb0</li> <li>\u6dfb\u52a0\u66f4\u591a\u5b9e\u9a8c\u62a5\u544a\uff08PDF + Markdown\uff09</li> <li>\u6574\u7406\u79d1\u7814\u5de5\u4f5c\u9605\u8bfb\u5217\u8868</li> <li>\u8bb0\u5f55\u89c2\u9e1f\u65e5\u8bb0</li> </ul>"},{"location":"appworld/","title":"\u5f00\u53d1\u8005\u4e16\u754c","text":"<p>\u81ea\u5df1\u5199\u7684\u4e00\u4e9b\u5c0f\u5de5\u5177\uff0c\u4e5f\u8bb8\u80fd\u5e2e\u4e0a\u5fd9\u3002</p>"},{"location":"appworld/#_2","title":"\u5de5\u5177\u5217\u8868","text":"<ul> <li> <p>\ud83d\udcda \u8003\u8bd5\u7ca5\u52a9\u624b</p> <p>AI \u9a71\u52a8\u7684\u667a\u80fd\u5907\u8003\u5de5\u5177\u3002\u4e0a\u4f20\u8d44\u6599\uff0c\u81ea\u52a8\u751f\u6210\u590d\u4e60\u7eb2\u8981\u3001\u7b14\u8bb0\u548c\u7ec3\u4e60\u9898\uff0c\u642d\u914d\u9519\u9898\u672c\u5b9e\u73b0\u9ad8\u6548\u590d\u4e60\u95ed\u73af\u3002</p> <p>:octicons-arrow-right-24: \u67e5\u770b\u8be6\u60c5</p> </li> <li> <p>\ud83d\udca1 \u66f4\u591a\u5de5\u5177\u5f00\u53d1\u4e2d</p> <p>\u65b0\u7684\u5c0f\u5de5\u5177\u6b63\u5728\u8def\u4e0a\uff0c\u656c\u8bf7\u671f\u5f85\u3002</p> </li> </ul>"},{"location":"appworld/exam-porridge-assistant/","title":"\u8003\u8bd5\u7ca5\u52a9\u624b","text":"<ul> <li> <p>:material-brain: AI \u9a71\u52a8</p> <p>\u81ea\u52a8\u751f\u6210\u590d\u4e60\u7eb2\u8981\u3001\u5b66\u4e60\u7b14\u8bb0\u548c\u7ec3\u4e60\u9898</p> </li> <li> <p>:material-database-off: \u6570\u636e\u5168\u672c\u5730</p> <p>\u6240\u6709\u6570\u636e\u5728\u6d4f\u89c8\u5668\u672c\u5730\uff0c\u65e0\u9700\u670d\u52a1\u5668</p> </li> <li> <p>:material-github: \u5f00\u6e90\u514d\u8d39</p> <p>\u4ee3\u7801\u5b8c\u5168\u5f00\u653e\uff0c\u81ea\u884c\u914d\u7f6e API Key \u5373\u53ef\u4f7f\u7528</p> </li> </ul>"},{"location":"appworld/exam-porridge-assistant/#_2","title":"\u7b80\u4ecb","text":"<p>\u8003\u8bd5\u7ca5\u52a9\u624b \u662f\u4e00\u4e2a AI \u9a71\u52a8\u7684\u667a\u80fd\u5907\u8003\u5de5\u5177\u3002\u4e0a\u4f20\u4f60\u7684\u5b66\u4e60\u8d44\u6599\uff08PDF / Word / TXT / \u56fe\u7247\uff09\uff0cAI \u81ea\u52a8\u5e2e\u4f60\u6574\u7406\u77e5\u8bc6\u3001\u751f\u6210\u590d\u4e60\u63d0\u7eb2\u548c\u5b66\u4e60\u7b14\u8bb0\u3001\u51fa\u9898\u7ec3\u4e60\uff0c\u642d\u914d\u9519\u9898\u672c\u5b9e\u73b0\u9ad8\u6548\u590d\u4e60\u95ed\u73af\u3002</p>"},{"location":"appworld/exam-porridge-assistant/#_3","title":"\u6838\u5fc3\u529f\u80fd","text":"<p>:material-file-document-outline:{ .lg .middle } \u77e5\u8bc6\u5e93\u7ba1\u7406</p> <p>\u4e0a\u4f20\u591a\u79cd\u683c\u5f0f\u7684\u5b66\u4e60\u8d44\u6599\uff0cAI \u81ea\u52a8\u63d0\u53d6\u6587\u672c\uff0c\u6309\u8bfe\u7a0b\u5206\u7c7b\u7ba1\u7406\u3002</p> <p>:material-book-search-outline:{ .lg .middle } \u590d\u4e60\u7eb2\u8981 &amp; \u5b66\u4e60\u7b14\u8bb0</p> <p>AI \u6839\u636e\u6587\u6863\u5185\u5bb9\u81ea\u52a8\u751f\u6210\u7ed3\u6784\u5316\u590d\u4e60\u7eb2\u8981\u548c\u8be6\u7ec6\u7b14\u8bb0\uff0c\u6db5\u76d6\u77e5\u8bc6\u70b9\u5f52\u7eb3\u4e0e\u91cd\u70b9\u89e3\u6790\u3002</p> <p>:material-head-question-outline:{ .lg .middle } \u667a\u80fd\u51fa\u9898</p> <p>\u652f\u6301\u9009\u62e9\u9898\u3001\u586b\u7a7a\u9898\u3001\u5224\u65ad\u9898\u3001\u7b80\u7b54\u9898\uff0c\u96be\u5ea6\u53ef\u8c03\uff0cAI \u6839\u636e\u5b66\u4e60\u5185\u5bb9\u81ea\u52a8\u51fa\u9898\u3002</p> <p>:material-close-circle-outline:{ .lg .middle } \u9519\u9898\u672c</p> <p>\u81ea\u52a8\u6536\u96c6\u9519\u9898\uff0c\u6807\u8bb0\u638c\u63e1\u7a0b\u5ea6\uff0c\u652f\u6301\u57fa\u4e8e\u9519\u9898\u91cd\u65b0\u51fa\u9898\u5f3a\u5316\u3002</p> <p>:material-file-upload-outline:{ .lg .middle } \u5237\u9898\u5668 &amp; OCR</p> <p>\u5bfc\u5165\u5df2\u6709\u8bd5\u5377\uff0cAI \u81ea\u52a8\u8bc6\u522b\u9898\u76ee\u7ed3\u6784\u5e76\u8865\u5168\u7b54\u6848\u3002\u652f\u6301\u56fe\u7247 OCR \u8bc6\u522b\u7eb8\u8d28\u8d44\u6599\u3002</p> <p>:material-shield-lock-outline:{ .lg .middle } \u9690\u79c1\u5b89\u5168</p> <p>\u6240\u6709\u6570\u636e\u5b58\u50a8\u5728\u6d4f\u89c8\u5668\u672c\u5730\uff0c\u4e0d\u7ecf\u8fc7\u4efb\u4f55\u670d\u52a1\u5668\u3002\u4ec5 AI \u8c03\u7528\u9700\u8981\u8054\u7f51\u3002</p>"},{"location":"appworld/exam-porridge-assistant/#_4","title":"\u5feb\u901f\u4e0a\u624b","text":""},{"location":"appworld/exam-porridge-assistant/#1","title":"1. \u83b7\u53d6\u9879\u76ee","text":"<pre><code>git clone https://github.com/zjuhechao/exam-porridge-assistant.git\ncd exam-porridge-assistant\nnpm install\nnpm run dev\n</code></pre> <p>\u6216\u8005\u76f4\u63a5\u4ece Release \u9875\u9762 \u4e0b\u8f7d\u6784\u5efa\u597d\u7684\u7248\u672c\u3002</p>"},{"location":"appworld/exam-porridge-assistant/#2-api","title":"2. \u914d\u7f6e API","text":"<p>\u6253\u5f00\u8bbe\u7f6e\u9875\u9762\uff0c\u586b\u5199\u4f60\u7684 AI API \u4fe1\u606f\uff1a</p> \u914d\u7f6e\u9879 \u8bf4\u660e \u793a\u4f8b API Base URL API \u670d\u52a1\u5730\u5740 <code>https://api.deepseek.com</code> API Key \u4f60\u7684\u5bc6\u94a5 <code>sk-...</code> \u6a21\u578b\u540d\u79f0 \u4f7f\u7528\u7684\u6a21\u578b <code>deepseek-chat</code> <p>\u652f\u6301 DeepSeek / OpenAI / Claude \u7b49\u6240\u6709\u517c\u5bb9 OpenAI \u683c\u5f0f\u7684 API\u3002</p>"},{"location":"appworld/exam-porridge-assistant/#3","title":"3. \u5f00\u59cb\u4f7f\u7528","text":"<ol> <li>\u521b\u5efa\u8bfe\u7a0b\uff0c\u4e0a\u4f20\u5b66\u4e60\u8d44\u6599</li> <li>\u4f7f\u7528\"\u590d\u4e60\u52a9\u624b\"\u751f\u6210\u7eb2\u8981\u548c\u7b14\u8bb0</li> <li>\u5728\"\u667a\u80fd\u7b54\u9898\"\u4e2d\u9009\u62e9\u6587\u6863\u548c\u9898\u578b\u8fdb\u884c\u7ec3\u4e60</li> <li>\u9519\u9898\u81ea\u52a8\u6536\u5165\u9519\u9898\u672c\uff0c\u9488\u5bf9\u6027\u5de9\u56fa</li> </ol>"},{"location":"appworld/exam-porridge-assistant/#_5","title":"\u6280\u672f\u7279\u70b9","text":"<ul> <li>\u7eaf\u524d\u7aef\uff1aReact + TypeScript + Webpack + Tailwind CSS</li> <li>\u672c\u5730\u5b58\u50a8\uff1aIndexedDB (Dexie) + localStorage\uff0c\u65e0\u9700\u540e\u7aef</li> <li>\u5b66\u79d1\u5b9a\u5236\uff1a\u6309\u6570\u5b66\u3001\u7269\u7406\u3001\u5316\u5b66\u3001\u8ba1\u7b97\u673a\u7b49\u5b66\u79d1\u5b9a\u5236 AI \u63d0\u793a\u8bcd</li> <li>\u591a API \u652f\u6301\uff1a\u53ef\u4e3a\u4e0d\u540c\u529f\u80fd\u5206\u914d\u4e0d\u540c\u7684 API \u914d\u7f6e</li> </ul>"},{"location":"appworld/exam-porridge-assistant/#_6","title":"\u94fe\u63a5","text":"<ul> <li>:simple-github: GitHub \u4ed3\u5e93</li> <li>:material-tag: \u53d1\u5e03\u5217\u8868</li> <li>:material-account: \u4f5c\u8005\u4e3b\u9875</li> </ul>"},{"location":"labs/","title":"\u5b9e\u9a8c\u62a5\u544a\u6c47\u603b","text":"<p>\u524d\u8a00</p> <p>\u5176\u5b9e\u5f88\u591a\u4e1c\u897f\u6211\u4eec\u90fd\u80fd\u627e\u5230\u53c2\u8003\u7684\uff0c\u5c31\u50cf\u662f\u5b9e\u9a8c\u62a5\u544a\uff0c\u4f60\u6284\u6211\u6765\u6211\u6284\u4f60\uff0c\u76ee\u7684\u4e00\u5728\u5b66\u5230\u5185\u5bb9\uff0c\u4e8c\u5728\u5b8c\u6210\u4efb\u52a1\uff0c\u5927\u6982\u540e\u8005\u66f4\u591a\u7f62\u3002\u8fd9\u4e9b\u662f\u963f\u5200\u7684\uff0c\u4e5f\u8bb8\u53ef\u4ee5\u53c2\u8003\u4e00\u4e0b\uff0c\u51cf\u5c11\u6709\u65f6\u5019\u4e00\u4e9b\u65e0\u7528\u7684\u5de5\u4f5c\uff0c\u5b66\u6211\u8005\u751f\uff0c\u4f3c\u6211\u8005\u522b\u6284\u4e00\u6a21\u4e00\u6837\uff0c\u795d\u597d\u3002</p>"},{"location":"labs/#_2","title":"\u2697\ufe0f \u65e0\u673a\u53ca\u5206\u6790\u5316\u5b66\u5b9e\u9a8c","text":"<p>\u65e0\u673a\u53ca\u5206\u6790\u5316\u5b66\u5b9e\u9a8c\u62a5\u544a </p>"},{"location":"labs/#_3","title":"\ud83e\uddea \u6709\u673a\u5316\u5b66\u5b9e\u9a8c","text":"<p>\u6709\u673a\u5316\u5b66\u5b9e\u9a8c\u62a5\u544a </p> <p>\u62d3\u5c55\u62a5\u544a\u2014\u2014\u690d\u7269\u7cbe\u6cb9\u7684\u63d0\u53d6\u4e0e\u5206\u6790 </p> <p>\u62d3\u5c55\u62