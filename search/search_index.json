{"config":{"lang":["en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u963f\u5200\u7684\u5168\u4e16\u754c","text":"<ul> <li> <p>\u81ea\u7559\u533a1</p> <p>1</p> </li> <li> <p>\u83dc\u56ed\u5b502</p> <p>2</p> </li> <li> <p>\u79cd\u5728\u5730\u91cc3</p> <p>3</p> </li> <li> <p>\u79cd\u70b9\u5c0f\u732b</p> <p>4</p> </li> </ul>"},{"location":"#_2","title":"\ud83d\udc4b \u5173\u4e8e\u6211","text":"<p>\u4ed6\u6211\u4ecb\u7ecd</p> <p>\u6682\u65f6\u662f\u4e00\u4e2a\u795e\u79d8\u7684\u4eba\uff0c\u4ec0\u4e48\u90fd\u6ca1\u6709\u5199\u3002\u201d</p> <p>GitHub\u4e3b\u9875 | 3230101238@zju.edu.cn</p>"},{"location":"#_3","title":"\ud83d\udd25 \u6700\u8fd1\u66f4\u65b0","text":"<p>\u201c\u8fd9\u91cc\u8fd8\u662f\u6bdb\u576f\u623f\uff0c\u4f46\u4f1a\u6162\u6162\u53d8\u6210\u6e29\u6696\u7684\u5bb6\u3002\u201d</p> <p>\u4ee5\u4e0b\u662f\u8fd1\u671f\u6574\u7406\u7684\u8bfe\u7a0b\u7b14\u8bb0\uff1a</p> <p>\u5176\u5b9e\u8fd8\u6b63\u5728\u505a</p>"},{"location":"#_4","title":"\ud83e\uddea \u5b9e\u9a8c\u62a5\u544a","text":"<ul> <li>\u7a0d\u7b49\uff0c\u4f1a\u6709\u7684</li> </ul>"},{"location":"#_5","title":"\ud83d\udcd6 \u8bfe\u7a0b\u7b14\u8bb0","text":""},{"location":"#_6","title":"\ud83d\udcc2 \u5185\u5bb9\u5bfc\u822a","text":"\u677f\u5757 \u7b80\u4ecb \u5feb\u901f\u5165\u53e3 \u79d1\u7814\u5de5\u4f5c \u8bba\u6587\u9605\u8bfb\u7b14\u8bb0\u4e0e\u79d1\u7814\u5fc3\u5f97 \u524d\u5f80 \u2192 \u8bba\u6587\u5206\u4eab \u7cbe\u8bfb\u7684\u597d\u8bba\u6587 \u524d\u5f80 \u2192 \u8bfb\u4e66\u7eaa\u8981 \u4e66\u6458\u4e0e\u8bfb\u540e\u611f \u524d\u5f80 \u2192 \u4ed6\u5c71\u4e4b\u77f3 \u5176\u4ed6\u5730\u65b9\u7684\u83ab\u540d\u5176\u5999\u7684\u6280\u80fd \u524d\u5f80 \u2192 \u8bfe\u7a0b \u4eba\u603b\u662f\u8981\u4e0a\u8bfe\u7684\u5427 \u524d\u5f80 \u2192 \u5f00\u53d1\u8005\u4e16\u754c \u6280\u672f\u5de5\u5177\u3001\u7f16\u7a0b\u6280\u5de7 \u524d\u5f80 \u2192 \u6742\u4e8b\u7eb7\u7ead \u505a\u7684\u5176\u4ed6\u7684\u4e0d\u52a1\u6b63\u4e1a\u7684\u4e8b\u60c5 \u524d\u5f80 \u2192 \u9e1f \u89c2\u9e1f\u8bb0\u5f55 \ud83d\udc26 \u524d\u5f80 \u2192 \u788e\u788e\u5ff5 \u65e5\u5e38\u77ed\u7bc7\u3001\u751f\u6d3b\u7410\u4e8b\u3001\u968f\u60f3 \u524d\u5f80 \u2192"},{"location":"#_7","title":"\ud83d\udea7 \u6b63\u5728\u52aa\u529b\u66f4\u65b0","text":"<p>\u8ba1\u5212</p> <ul> <li>\u5b8c\u5584\u8bfe\u7a0b\u7b14\u8bb0</li> <li>\u6dfb\u52a0\u66f4\u591a\u5b9e\u9a8c\u62a5\u544a\uff08PDF + Markdown\uff09</li> <li>\u6574\u7406\u79d1\u7814\u5de5\u4f5c\u9605\u8bfb\u5217\u8868</li> <li>\u8bb0\u5f55\u89c2\u9e1f\u65e5\u8bb0</li> </ul>"},{"location":"appworld/","title":"\u5f00\u53d1\u8005\u4e16\u754c","text":"<p>\u81ea\u5df1\u5199\u7684\u4e00\u4e9b\u5c0f\u5de5\u5177\uff0c\u4e5f\u8bb8\u80fd\u5e2e\u4e0a\u5fd9\u3002</p>"},{"location":"appworld/#_2","title":"\u5de5\u5177\u5217\u8868","text":"<ul> <li> <p>\ud83d\udcda \u8003\u8bd5\u7ca5\u52a9\u624b</p> <p>AI \u9a71\u52a8\u7684\u667a\u80fd\u5907\u8003\u5de5\u5177\u3002\u4e0a\u4f20\u8d44\u6599\uff0c\u81ea\u52a8\u751f\u6210\u590d\u4e60\u7eb2\u8981\u3001\u7b14\u8bb0\u548c\u7ec3\u4e60\u9898\uff0c\u642d\u914d\u9519\u9898\u672c\u5b9e\u73b0\u9ad8\u6548\u590d\u4e60\u95ed\u73af\u3002</p> <p>\u67e5\u770b\u8be6\u60c5</p> </li> <li> <p>\ud83d\udca1 \u66f4\u591a\u5de5\u5177\u5f00\u53d1\u4e2d</p> <p>\u65b0\u7684\u5c0f\u5de5\u5177\u6b63\u5728\u8def\u4e0a\uff0c\u656c\u8bf7\u671f\u5f85\u3002</p> </li> </ul>"},{"location":"appworld/exam-porridge-assistant/","title":"\u8003\u8bd5\u7ca5\u52a9\u624b","text":"<p>\u4e00\u6b3e\u57fa\u4e8e AI \u7684\u672c\u5730\u5316\u5b66\u4e60\u4e0e\u8003\u8bd5\u8f85\u52a9\u5de5\u5177\u3002</p> <p>\u4e0a\u4f20\u8d44\u6599\uff0cAI \u81ea\u52a8\u751f\u6210\u590d\u4e60\u7eb2\u8981\u3001\u5b66\u4e60\u7b14\u8bb0\u548c\u7ec3\u4e60\u9898\uff0c\u652f\u6301\u5237\u9898\u3001\u9519\u9898\u8ffd\u8e2a\u548c\u9488\u5bf9\u6027\u8bad\u7ec3\u3002</p> <p>\u6240\u6709\u6570\u636e\u5b8c\u5168\u5b58\u50a8\u5728\u672c\u5730\u6d4f\u89c8\u5668\u4e2d\uff0c\u4e0d\u4f9d\u8d56\u4efb\u4f55\u4e91\u7aef\u670d\u52a1\u3002</p>"},{"location":"appworld/exam-porridge-assistant/#_2","title":"\ud83d\udccb \u529f\u80fd\u4e00\u89c8","text":"<ul> <li>\u591a\u683c\u5f0f\u8d44\u6599\u4e0a\u4f20\uff1a\u652f\u6301 PDF\u3001DOCX\u3001TXT\u3001\u56fe\u7247\u7b49\u683c\u5f0f\uff0c\u81ea\u52a8\u63d0\u53d6\u6587\u672c\u6216 OCR \u8bc6\u522b</li> <li>AI \u590d\u4e60\u7eb2\u8981\uff1a\u667a\u80fd\u751f\u6210\u7ed3\u6784\u5316\u590d\u4e60\u7eb2\u8981\u548c\u5b66\u4e60\u7b14\u8bb0</li> <li>\u667a\u80fd\u51fa\u9898\uff1a\u81ea\u52a8\u751f\u6210\u9009\u62e9\u9898\u3001\u586b\u7a7a\u9898\u3001\u5224\u65ad\u9898\u3001\u7b80\u7b54\u9898</li> <li>\u5237\u9898\u5668\u6a21\u5f0f\uff1a\u5bfc\u5165\u5df2\u6709\u9898\u76ee\u6587\u4ef6\u6216\u8bd5\u5377\u56fe\u7247\uff0cAI \u81ea\u52a8\u8bc6\u522b\u9898\u76ee</li> <li>\u9519\u9898\u8ffd\u8e2a\uff1a\u81ea\u52a8\u6536\u96c6\u9519\u9898\uff0c\u9488\u5bf9\u6027\u5f3a\u5316\u8bad\u7ec3</li> <li>\u8bfe\u7a0b\u7ba1\u7406\uff1a\u6309\u8bfe\u7a0b\u9694\u79bb\u7ba1\u7406\u6240\u6709\u5b66\u4e60\u6570\u636e</li> </ul>"},{"location":"appworld/exam-porridge-assistant/#_3","title":"\ud83d\ude80 \u5feb\u901f\u4e0a\u624b","text":""},{"location":"appworld/exam-porridge-assistant/#git","title":"\u7b2c\u4e00\u6b65\uff1a\u5b89\u88c5 Git","text":"<p>Git \u662f\u4e00\u4e2a\u4ee3\u7801\u7ba1\u7406\u5de5\u5177\uff0c\u7528\u6765\u628a\u9879\u76ee\u4ece GitHub \u4e0b\u8f7d\u5230\u4f60\u7684\u7535\u8111\u4e0a\u3002</p> Windows\uff08\u70b9\u51fb\u5c55\u5f00\uff09 <ol> <li>\u6253\u5f00\u6d4f\u89c8\u5668\uff0c\u8bbf\u95ee https://git-scm.com/downloads</li> <li>\u70b9\u51fb Windows \u7248\u672c\u4e0b\u8f7d\uff08\u4f1a\u81ea\u52a8\u4e0b\u8f7d\u4e00\u4e2a <code>.exe</code> \u5b89\u88c5\u6587\u4ef6\uff09</li> <li>\u53cc\u51fb\u5b89\u88c5\u6587\u4ef6\uff0c\u4e00\u8def\u70b9 Next\uff0c\u6240\u6709\u9009\u9879\u4fdd\u6301\u9ed8\u8ba4\u5373\u53ef</li> <li>\u5b89\u88c5\u5b8c\u6210\u540e\u70b9\u51fb Finish</li> </ol> macOS\uff08\u70b9\u51fb\u5c55\u5f00\uff09 <ol> <li>\u6253\u5f00\u7ec8\u7aef\uff08\u6309 <code>Cmd + \u7a7a\u683c</code> \u641c\u7d22\"\u7ec8\u7aef\"\uff09</li> <li> <p>\u5b89\u88c5 Homebrew\uff08\u82e5\u5df2\u5b89\u88c5\u53ef\u8df3\u8fc7\uff09\uff1a</p> <pre><code>/bin/bash -c \"$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\"\n</code></pre> </li> <li> <p>\u901a\u8fc7 Homebrew \u5b89\u88c5 Git\uff1a</p> <pre><code>brew install git\n</code></pre> </li> </ol> Linux\uff08\u4ee5 Ubuntu \u4e3a\u4f8b\uff09\uff08\u70b9\u51fb\u5c55\u5f00\uff09 <ol> <li>\u6253\u5f00\u7ec8\u7aef\uff08<code>Ctrl + Alt + T</code>\uff09</li> <li> <p>\u66f4\u65b0\u8f6f\u4ef6\u5305\u5217\u8868\u5e76\u5b89\u88c5 Git\uff1a</p> <pre><code>sudo apt update\nsudo apt install git -y\n</code></pre> </li> </ol> <p>\u5176\u4ed6\u53d1\u884c\u7248\uff1aFedora \u4f7f\u7528 <code>sudo dnf install git</code>\uff0cArch Linux \u4f7f\u7528 <code>sudo pacman -S git</code>\u3002</p> <p>\u9a8c\u8bc1\u5b89\u88c5\uff1a \u5728\u7ec8\u7aef\u4e2d\u8f93\u5165\uff1a</p> <pre><code>git --version\n</code></pre> <p>\u770b\u5230\u7c7b\u4f3c <code>git version 2.xx.x</code> \u7684\u8f93\u51fa\u5373\u5b89\u88c5\u6210\u529f\u3002</p>"},{"location":"appworld/exam-porridge-assistant/#nodejs","title":"\u7b2c\u4e8c\u6b65\uff1a\u5b89\u88c5 Node.js","text":"<p>Node.js \u662f\u8fd0\u884c\u672c\u9879\u76ee\u6240\u5fc5\u9700\u7684 JavaScript \u8fd0\u884c\u65f6\u3002</p> Windows\uff08\u70b9\u51fb\u5c55\u5f00\uff09 <ol> <li>\u6253\u5f00\u6d4f\u89c8\u5668\uff0c\u8bbf\u95ee https://nodejs.org/zh-cn</li> <li>\u70b9\u51fb LTS\uff08\u957f\u671f\u652f\u6301\u7248\uff09 \u4e0b\u8f7d\u6309\u94ae</li> <li>\u53cc\u51fb\u4e0b\u8f7d\u597d\u7684 <code>.msi</code> \u5b89\u88c5\u6587\u4ef6\uff0c\u4e00\u8def\u70b9 Next</li> <li>\u5982\u679c\u770b\u5230 \"Automatically install the necessary tools\" \u9009\u9879\uff0c\u52fe\u9009\u5b83</li> <li>\u70b9\u51fb Install\uff0c\u7b49\u5f85\u5b89\u88c5\u5b8c\u6210\uff0c\u70b9\u51fb Finish</li> </ol> macOS\uff08\u70b9\u51fb\u5c55\u5f00\uff09 <p>\u65b9\u6cd5\u4e00\uff08\u63a8\u8350\uff09\uff1a\u4f7f\u7528 Homebrew</p> <pre><code>brew install node\n</code></pre> <p>\u65b9\u6cd5\u4e8c\uff1a\u4ece\u5b98\u7f51\u4e0b\u8f7d</p> <ol> <li>\u6253\u5f00\u6d4f\u89c8\u5668\uff0c\u8bbf\u95ee https://nodejs.org/zh-cn</li> <li>\u70b9\u51fb LTS\uff08\u957f\u671f\u652f\u6301\u7248\uff09 \u4e0b\u8f7d\u6309\u94ae</li> <li>\u53cc\u51fb\u4e0b\u8f7d\u597d\u7684 <code>.pkg</code> \u5b89\u88c5\u6587\u4ef6\uff0c\u6309\u63d0\u793a\u5b8c\u6210\u5b89\u88c5</li> </ol> Linux\uff08\u4ee5 Ubuntu \u4e3a\u4f8b\uff09\uff08\u70b9\u51fb\u5c55\u5f00\uff09 <pre><code>sudo apt update\nsudo apt install nodejs npm -y\n</code></pre> <p>\u5982\u9700\u6700\u65b0\u7248\u672c\uff0c\u5efa\u8bae\u4f7f\u7528 nvm \u5b89\u88c5\uff1a</p> <pre><code>curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh | bash\n# \u91cd\u542f\u7ec8\u7aef\u540e\nnvm install --lts\n</code></pre> <p>\u9a8c\u8bc1\u5b89\u88c5\uff1a \u5728\u7ec8\u7aef\u4e2d\u8f93\u5165\uff1a</p> <pre><code>node --version\nnpm --version\n</code></pre> <p>\u770b\u5230\u7c7b\u4f3c <code>v20.11.0</code> \u548c <code>10.2.4</code> \u7684\u7248\u672c\u53f7\u5373\u6210\u529f\u3002</p>"},{"location":"appworld/exam-porridge-assistant/#_4","title":"\u7b2c\u4e09\u6b65\uff1a\u4e0b\u8f7d\u9879\u76ee\u4ee3\u7801","text":"<p>\u6253\u5f00\u7ec8\u7aef\uff0c\u8fdb\u5165\u4f60\u5e0c\u671b\u5b58\u653e\u9879\u76ee\u7684\u76ee\u5f55\uff0c\u7136\u540e\u8fd0\u884c\uff1a</p> <pre><code>git clone https://github.com/zjuhechao/exam-porridge-assistant.git\ncd exam-porridge-assistant\n</code></pre>"},{"location":"appworld/exam-porridge-assistant/#_5","title":"\u7b2c\u56db\u6b65\uff1a\u5b89\u88c5\u9879\u76ee\u4f9d\u8d56","text":"<pre><code>npm install\n</code></pre> <p>\u9996\u6b21\u5b89\u88c5\u9700\u8981\u4e0b\u8f7d\u7ea6 200MB \u7684\u4f9d\u8d56\u5305\uff0c\u8017\u65f6 2-5 \u5206\u949f\u3002\u51fa\u73b0\u9ec4\u8272\u7684 <code>WARN</code> \u8b66\u544a\u662f\u6b63\u5e38\u7684\u3002</p> <p>\u5982\u679c\u5b89\u88c5\u5f88\u6162\u6216\u5931\u8d25\uff1a \u5207\u6362\u5230\u56fd\u5185\u955c\u50cf\u6e90\u540e\u91cd\u8bd5\uff1a <pre><code>npm config set registry https://registry.npmmirror.com\nnpm install\n</code></pre></p>"},{"location":"appworld/exam-porridge-assistant/#_6","title":"\u7b2c\u4e94\u6b65\uff1a\u542f\u52a8\u9879\u76ee","text":"<pre><code>npm run dev\n</code></pre> <p>\u7b49\u5f85\u51e0\u79d2\u949f\uff0c\u5f53\u7ec8\u7aef\u663e\u793a <code>webpack compiled successfully</code> \u65f6\uff0c\u8bf4\u660e\u542f\u52a8\u6210\u529f\u3002</p> <p>\u542f\u52a8\u540e\u8fd9\u4e2a\u7ec8\u7aef\u7a97\u53e3\u4e0d\u8981\u5173\u95ed\uff0c\u5173\u95ed\u7ec8\u7aef\u5373\u5173\u95ed\u5e94\u7528\u3002</p>"},{"location":"appworld/exam-porridge-assistant/#_7","title":"\u7b2c\u516d\u6b65\uff1a\u6253\u5f00\u5e94\u7528","text":"<p>\u6253\u5f00\u6d4f\u89c8\u5668\uff0c\u5728\u5730\u5740\u680f\u8f93\u5165\uff1a</p> <pre><code>http://localhost:3015\n</code></pre> <p>\u6309\u56de\u8f66\uff0c\u5373\u53ef\u770b\u5230\u8003\u8bd5\u7ca5\u52a9\u624b\u7684\u9996\u9875\u3002</p>"},{"location":"appworld/exam-porridge-assistant/#_8","title":"\u2699\ufe0f \u6280\u672f\u6808","text":"\u5c42 \u6280\u672f \u524d\u7aef\u6846\u67b6 React 18 + TypeScript \u8def\u7531 react-router-dom v6 \u6837\u5f0f Tailwind CSS 3 \u52a8\u753b framer-motion \u672c\u5730\u6570\u636e\u5e93 Dexie (IndexedDB) PDF \u89e3\u6790 pdfjs-dist DOCX \u89e3\u6790 mammoth \u6784\u5efa\u5de5\u5177 Webpack 5 AI \u63a5\u53e3 OpenAI \u517c\u5bb9\u683c\u5f0f\uff08\u652f\u6301\u591a\u6a21\u6001\uff09"},{"location":"appworld/exam-porridge-assistant/#_9","title":"\ud83d\udd17 \u94fe\u63a5","text":"<ul> <li> <p>GitHub \u4ed3\u5e93</p> <p>\u6d4f\u89c8\u5b8c\u6574\u6e90\u7801\u3001\u63d0\u4ea4 Issue \u6216 Star \u652f\u6301\u3002</p> <p>\u524d\u5f80\u4ed3\u5e93 \u2192</p> </li> </ul>"},{"location":"labs/","title":"\u5b9e\u9a8c\u62a5\u544a\u6c47\u603b","text":"